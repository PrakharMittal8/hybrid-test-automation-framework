<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Hybrid Automation Suite"
       parallel="tests"
       thread-count="4">

    <!-- Listener -->
    <listeners>
        <listener class-name="com.automation.listeners.TestListener"/>
    </listeners>

    <!-- API Test Execution -->
    <test name="API Tests">
        <classes>
            <class name="com.automation.tests.ApiE2ETest"/>
        </classes>
    </test>

    <!-- UI Functional Tests -->
    <test name="UI Tests">
        <classes>
            <class name="com.automation.tests.AddToCartTest"/>
        </classes>
    </test>

    <!-- Data Driven Tests -->
    <test name="Data Driven Tests">
        <classes>
            <class name="com.automation.tests.DataDrivenOrderTest"/>
        </classes>
    </test>

    <!-- BDD Tests -->
    <test name="BDD Tests">
        <classes>
            <class name="com.automation.tests.TestRunner"/>
        </classes>
    </test>

</suite>